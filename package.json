{
  "name": "holy-quest-ai",
  "displayName": "Holy Quest AI: AI Assistant",
  "description": "AI-powered coding assistant for Holy Fact Quest project",
  "version": "1.0.0",
  "publisher": "holy-quest",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "holyQuestAI",
          "title": "Holy Quest AI",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "holyQuestAI": [
        {
          "type": "webview",
          "id": "holyQuestAIView",
          "name": "AI Assistant"
        }
      ]
    },
    "commands": [
      {
        "command": "holyQuestAI.openChat",
        "title": "Holy Quest AI: Open Chat"
      },
      {
        "command": "holyQuestAI.clearChat",
        "title": "Holy Quest AI: Clear Chat"
      }
    ],
    "configuration": {
      "title": "Holy Quest AI",
      "properties": {
        "holyQuestAI.apiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API Key"
        },
        "holyQuestAI.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API Key (alternate)"
        },
        "holyQuestAI.allowFileEdits": {
          "type": "boolean",
          "default": true,
          "description": "Allow AI to edit files directly"
        },
        "holyQuestAI.fileSystemAccess": {
          "type": "boolean",
          "default": true,
          "description": "Grant file system access"
        },
        "holyQuestAI.experimentalFeatures": {
          "type": "boolean",
          "default": true,
          "description": "Enable experimental AI features"
        },
        "holyQuestAI.autoExecuteCommands": {
          "type": "boolean",
          "default": false,
          "description": "Automatically execute terminal commands (use with caution)"
        },
        "holyQuestAI.maxTokens": {
          "type": "number",
          "default": 200000,
          "description": "Maximum conversation tokens before warning"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.4.1",
    "@typescript-eslint/parser": "^6.4.1",
    "@vscode/test-electron": "^2.3.4",
    "eslint": "^8.47.0",
    "glob": "^10.3.3",
    "jest": "^30.3.0",
    "mocha": "^10.2.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0"
  }
}
